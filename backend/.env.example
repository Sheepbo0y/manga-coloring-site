# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置 (Railway 会自动设置 DATABASE_URL)
DATABASE_URL="postgresql://user:password@localhost:5432/manga_coloring?schema=public"

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# 前端 URL (CORS)
FRONTEND_URL="http://localhost:5173"

# Redis 配置 (用于任务队列)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ComfyUI 配置
COMFYUI_API_URL="http://localhost:8188"

# Seedream API 配置
SEEDREAM_API_KEY="your-seedream-api-key-here"

# 上传配置
MAX_FILE_SIZE="10485760"
UPLOAD_DIR="./uploads"

# Cloudinary 配置（可选，配置后使用云存储代替本地存储）
# 注册地址：https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
