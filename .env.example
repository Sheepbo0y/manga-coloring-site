# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/manga_coloring?schema=public"

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ComfyUI API 配置
COMFYUI_API_URL=http://localhost:8188
COMFYUI_API_KEY=

# 服务器配置
PORT=3001
FRONTEND_URL=http://localhost:5173

# Node 环境
NODE_ENV=development
